# ──────────────────────────────────────────────
# MONNAIE — Flutter .gitignore
# ──────────────────────────────────────────────

# ── Flutter / Dart ────────────────────────────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
pubspec.lock          # Commit this for apps (remove line to track it)



# ── Android ───────────────────────────────────
android/.gradle/
android/captures/
android/gradlew
android/gradlew.bat
android/local.properties
android/key.properties          # ← signing keystore config — NEVER commit
android/app/google-services.json # ← Firebase config — NEVER commit
**/android/app/*.jks            # keystore files
**/android/app/*.keystore
android/.idea/
android/app/release/
android/app/profile/

# ── iOS ───────────────────────────────────────
ios/.symlinks/
ios/Flutter/flutter_export_environment.sh
ios/Flutter/Generated.xcconfig
ios/Flutter/App.framework
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Pods/
ios/Podfile.lock
ios/.flutter-plugins
ios/Runner.xcworkspace/xcuserdata/
ios/Runner.xcodeproj/xcuserdata/
ios/Runner.xcodeproj/project.xcworkspace/xcuserdata/
GoogleService-Info.plist        # ← Firebase config — NEVER commit

# ── macOS ─────────────────────────────────────
macos/Flutter/ephemeral/
macos/Pods/
macos/Podfile.lock

# ── Windows ───────────────────────────────────
windows/flutter/generated_plugin_registrant.cc
windows/flutter/generated_plugin_registrant.h
windows/flutter/generated_plugins.cmake

# ── Linux ─────────────────────────────────────
linux/flutter/generated_plugin_registrant.cc
linux/flutter/generated_plugin_registrant.h
linux/flutter/generated_plugins.cmake

# ── Web ───────────────────────────────────────
lib/generated_plugin_registrant.dart

# ── IDEs ──────────────────────────────────────
.idea/
.vscode/settings.json
.vscode/launch.json
*.iml
*.ipr
*.iws
.DS_Store
Thumbs.db

# ── Environment / Secrets ─────────────────────
.env
.env.local
.env.production
*.pem
*.p8
secrets.dart
config/secrets/

# ── Hive local database (device data) ─────────
*.hive
*.lock

# ── Coverage & Test output ────────────────────
coverage/
test/coverage/
*.lcov

# ── Misc ──────────────────────────────────────
*.log
*.bak
*.tmp
*.orig

# ── Secrets (NEVER commit) ─────────────────────────────────────────────────
lib/core/config/supabase_config.dart